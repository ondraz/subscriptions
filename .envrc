dotenv

# Wire app secrets to Terraform variables (TF_VAR_ prefix)
export TF_VAR_stripe_api_key="${STRIPE_API_KEY}"
export TF_VAR_stripe_webhook_secret="${STRIPE_WEBHOOK_SECRET}"
export TF_VAR_clerk_publishable_key="${CLERK_PUBLISHABLE_KEY}"
export TF_VAR_clerk_secret_key="${CLERK_SECRET_KEY}"
export TF_VAR_clerk_jwks_url="${CLERK_JWKS_URL}"
