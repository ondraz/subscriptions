meta {
  name: Trial conversion rate
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/metrics/trials?start={{start}}&end={{end}}
  body: none
  auth: bearer
}

params:query {
  start: {{start}}
  end: {{end}}
}

auth:bearer {
  token: {{apiKey}}
}

docs {
  Share of trials that converted to a paid subscription. Wide windows
  recommended; narrow ones often have zero trial starts and collapse to
  null.
}
